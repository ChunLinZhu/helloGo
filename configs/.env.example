# ============================================================
# webdemo 配置模板 — 复制为 .env.development 或 .env.production
# ============================================================

# ── 通用 ──────────────────────────────────────────────────
APP_ENV=development
PORT=8000

# ── 数据库 ────────────────────────────────────────────────
# 类型: sqlite / mysql / postgres
DB_TYPE=sqlite
SQLITE_PATH=./data/sqlite.db

# MySQL（DB_TYPE=mysql 时生效）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=11111
DB_NAME=webdemo

# PostgreSQL（DB_TYPE=postgres 时生效）
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASS=webdemo
PG_DB=webdemo

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=11111

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=change_me_please
JWT_EXPIRES=1d
JWT_REFRESH_EXPIRES=7d

# ── 安全 ──────────────────────────────────────────────────
CSRF_ENABLED=true
CSRF_MODE=header
CSRF_SECRET=change-me
CORS_ORIGINS=*

# ── 限流 ──────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── 指标 ──────────────────────────────────────────────────
ENABLE_METRICS=true

# ── Swagger ───────────────────────────────────────────────
SWAGGER_ENABLE=true

# ── 文件上传 ──────────────────────────────────────────────
UPLOAD_DEST=./upload
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,application/pdf
UPLOAD_CLEAN_INTERVAL_SEC=3600
UPLOAD_TTL_DAYS=30

# ── 登录安全 ──────────────────────────────────────────────
LOGIN_MAX_FAILS=5
LOGIN_LOCK_TTL=600
