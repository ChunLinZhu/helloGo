# Auth Service 配置（gRPC 微服务）
APP_ENV=development
GRPC_PORT=50002

# Redis（Auth Service 必须连接 Redis，用于会话管理和登录锁定）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=11111

# JWT
JWT_SECRET=dev-secret-key-do-not-use-in-production
JWT_EXPIRES=1d
JWT_REFRESH_EXPIRES=7d

# User Service 地址（Auth Service 通过 gRPC 调用 User Service 验证密码）
USER_SERVICE_ADDR=localhost:50001

# 登录安全
LOGIN_MAX_FAILS=5
LOGIN_LOCK_TTL=600
